generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id                String             @id @db.Uuid
  wid               Int                @unique
  email             String             @unique
  fullName          String
  plan              Plan               @default(FREE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  bookingEventTypes BookingEventType[]
  scheduledMeetings ScheduledMeeting[]
  bookedMeetings    BookedMeeting[]
  contacts          Contact[]
  integrations      IntegrationConnection[]
  availabilityHours AvailabilityWeeklyHour[]
  availabilityOverrides AvailabilityOverride[]
  subscriptions     Subscription[]
  transactions      Transaction[]
  platformBranding  Boolean            @default(true) @map("platform_branding")
  workspaceLogo     String?            @map("workspace_logo")
  linkSlug          String?            @unique @map("link_slug")

  @@map("user_profiles")
}

enum Plan {
  FREE
  PRO
}

/// Matches sidebar "One-on-one" | "Group" | "Round robin" (`scheduling-event-types.ts`).
enum BookingEventKind {
  ONE_ON_ONE
  GROUP
  ROUND_ROBIN
}

/// A saved bookable event configuration from the scheduling drawer (per host).
model BookingEventType {
  id                 String             @id @default(uuid()) @db.Uuid
  hostId             String             @db.Uuid
  wid                Int
  host               UserProfile        @relation(fields: [hostId], references: [id], onDelete: Cascade)
  kind               BookingEventKind
  eventName          String
  durationMinutes    Int
  /// UI values: google-meet | zoom | phone | in-person
  location           String
  description        String?
  /// working-hours | weekday-mornings | custom
  availabilityPreset String
  /// e.g. 1h, 4h, 12h, 24h
  minNotice          String
  bufferBeforeMinutes Int
  bufferAfterMinutes Int
  /// e.g. 14d, 30d, 60d, 90d
  bookingWindow      String
  bookingQuestion    String?
  /// Public /book/[host] layout template: simple | vintage | modern | compact | editorial
  bookingPageTheme   String             @default("simple") @map("booking_page_theme")
  /// When true, guests must complete payment (see paymentProvider) before the slot is booked.
  paymentEnabled       Boolean            @default(false) @map("payment_enabled")
  /// e.g. razorpay — null when paymentEnabled is false
  paymentProvider      String?            @map("payment_provider")
  /// Amount in smallest currency unit (paise for INR)
  paymentAmountPaisa   Int?               @map("payment_amount_paisa")
  /// Shown in Razorpay checkout and on the public booking page (e.g. Consultation fee)
  paymentLabel         String?            @map("payment_label")
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  weekSlots          BookingWeekSlot[]
  scheduledMeetings  ScheduledMeeting[]
  bookedMeetings     BookedMeeting[]

  @@index([hostId])
  @@index([wid, hostId])
  @@map("booking_event_types")
}

enum ScheduledMeetingStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

enum IntegrationProvider {
  GOOGLE
  CASHFREE
  ZOOM
  /// Host Key ID in `accessToken`, Key Secret in `refreshToken`, webhook signing secret in `scope` (optional).
  RAZORPAY
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum TransactionStatus {
  CREATED
  SUCCESS
  FAILED
}

enum ContactInquiryStatus {
  NEW
  IN_REVIEW
  RESOLVED
}

/// Host-created meeting row (dashboard / internal). Public link bookings use `BookedMeeting`.
model ScheduledMeeting {
  id             String                 @id @default(uuid()) @db.Uuid
  hostId         String                 @db.Uuid
  wid            Int
  host           UserProfile            @relation(fields: [hostId], references: [id], onDelete: Cascade)
  eventTypeId    String?                @db.Uuid
  eventType      BookingEventType?      @relation(fields: [eventTypeId], references: [id], onDelete: SetNull)
  title          String
  /// Display string: One-on-one, Group, Round robin (matches UI mock).
  eventTypeLabel String
  guestName      String
  meetingLink    String?
  startsAt       DateTime
  endsAt         DateTime?
  status         ScheduledMeetingStatus @default(UPCOMING)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([hostId])
  @@index([wid, hostId])
  @@index([wid, hostId, startsAt])
  @@map("scheduled_meetings")
}

/// Guest booking from a public booking link (separate from host-created `ScheduledMeeting` rows).
model BookedMeeting {
  id          String                 @id @default(uuid()) @db.Uuid
  hostId      String                 @db.Uuid
  wid         Int
  host        UserProfile            @relation(fields: [hostId], references: [id], onDelete: Cascade)
  eventTypeId String                 @db.Uuid
  eventType   BookingEventType       @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  guestName   String
  guestEmail  String
  meetingLink String?
  guestCountryCode String?
  guestPhone  String?
  guestNotes  String?
  startsAt    DateTime
  endsAt      DateTime
  status      ScheduledMeetingStatus @default(UPCOMING)
  /// Set when booking required Razorpay; prevents reusing the same payment.
  razorpayPaymentId String? @unique @map("razorpay_payment_id")
  razorpayOrderId   String? @map("razorpay_order_id")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([hostId])
  @@index([wid, hostId])
  @@index([eventTypeId, startsAt])
  @@index([hostId, startsAt])
  @@map("booked_meetings")
}

/// Host contacts (people who booked or were added manually).
model Contact {
  id         String      @id @default(uuid()) @db.Uuid
  hostId     String      @db.Uuid
  wid        Int
  host       UserProfile @relation(fields: [hostId], references: [id], onDelete: Cascade)
  fullName   String
  email      String
  countryCode String?
  phone      String?
  lastBookedAt DateTime?
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([hostId, email])
  @@index([wid, hostId])
  @@map("contacts")
}

model IntegrationConnection {
  id           String              @id @default(uuid()) @db.Uuid
  hostId       String              @db.Uuid
  wid          Int
  host         UserProfile         @relation(fields: [hostId], references: [id], onDelete: Cascade)
  provider     IntegrationProvider
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([hostId, provider])
  @@index([wid, hostId])
  @@map("integration_connections")
}

/// Weekly grid from the sidebar (Mon–Sun); snapshot at save (including non-custom presets).
model BookingWeekSlot {
  id          String           @id @default(uuid()) @db.Uuid
  eventTypeId String           @db.Uuid
  eventType   BookingEventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  /// Mon, Tue, … Sun — matches scheduling page `DaySchedule.day`
  dayKey      String
  enabled     Boolean
  /// HH:mm
  startTime   String
  endTime     String

  @@unique([eventTypeId, dayKey])
  @@map("booking_week_slots")
}

/// Workspace-scoped weekly availability for host booking pages.
model AvailabilityWeeklyHour {
  id        String      @id @default(uuid()) @db.Uuid
  hostId    String      @db.Uuid
  host      UserProfile @relation(fields: [hostId], references: [id], onDelete: Cascade)
  wid       Int
  /// 1=Monday ... 7=Sunday
  dayOfWeek Int
  enabled   Boolean     @default(true)
  /// HH:mm
  startTime String
  /// HH:mm
  endTime   String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([hostId, wid, dayOfWeek])
  @@index([wid, hostId])
  @@map("availability_weekly_hours")
}

/// Date-specific availability override windows (used to block or customize one day).
model AvailabilityOverride {
  id        String      @id @default(uuid()) @db.Uuid
  hostId    String      @db.Uuid
  host      UserProfile @relation(fields: [hostId], references: [id], onDelete: Cascade)
  wid       Int
  date      DateTime    @db.Date
  /// HH:mm (ignored when isAllDay = true)
  startTime String?
  /// HH:mm (ignored when isAllDay = true)
  endTime   String?
  isAllDay  Boolean     @default(false)
  label     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([hostId, wid, date])
  @@index([wid, hostId])
  @@map("availability_overrides")
}

model Subscription {
  id                  String             @id @default(uuid()) @db.Uuid
  hostId              String             @db.Uuid
  wid                 Int
  host                UserProfile        @relation(fields: [hostId], references: [id], onDelete: Cascade)
  plan                Plan
  status              SubscriptionStatus @default(PENDING)
  provider            String
  providerOrderId     String?
  providerPaymentId   String?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  startedAt           DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  transactions        Transaction[]

  @@index([hostId])
  @@index([wid, hostId])
  @@index([hostId, status])
  @@map("subscriptions")
}

model Transaction {
  id                String            @id @default(uuid()) @db.Uuid
  hostId            String            @db.Uuid
  wid               Int
  host              UserProfile       @relation(fields: [hostId], references: [id], onDelete: Cascade)
  subscriptionId    String?           @db.Uuid
  subscription      Subscription?     @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  status            TransactionStatus @default(CREATED)
  provider          String
  amount            Int
  currency          String            @default("INR")
  providerOrderId   String?
  providerPaymentId String?
  providerSignature String?
  description       String?
  metadata          Json?
  paidAt            DateTime?
  failedAt          DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([hostId])
  @@index([wid, hostId])
  @@index([hostId, status])
  @@index([providerOrderId])
  @@map("transactions")
}

model ContactInquiry {
  id        String              @id @default(uuid()) @db.Uuid
  fullName  String
  email     String
  phone     String?
  subject   String?
  message   String
  status    ContactInquiryStatus @default(NEW)
  source    String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([email])
  @@index([status, createdAt])
  @@map("contact_inquiries")
}
