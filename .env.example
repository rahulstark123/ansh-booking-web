NEXT_PUBLIC_SUPABASE_URL=
# Use either JWT anon key (legacy) or new publishable key from Supabase dashboard:
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Canonical browser URL (e.g. https://yourdomain.com). Used for Razorpay webhook URL in Integrations when the client has no origin.
NEXT_PUBLIC_APP_URL=
# Optional server-only aliases (API route also reads these):
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Prisma + Supabase (pooler — from Dashboard → Connect → ORM: Prisma)
# Port 6543 + pgbouncer=true = transaction pooler (Next API / `src/lib/prisma.ts`)
# Port 5432 on same host = session mode for Prisma CLI (`prisma.config.ts` uses DIRECT_URL first)
# Example (replace password; URL-encode @ # in password):
# DATABASE_URL="postgresql://postgres.eajcpzzegjpixkhaohjd:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# DIRECT_URL="postgresql://postgres.eajcpzzegjpixkhaohjd:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require"
DATABASE_URL=
DIRECT_URL=

# Transactional email (booking confirmations) — e.g. Hostinger business mail
# Host: smtp.hostinger.com | Port 465 + SMTP_SECURE=true (SSL), or 587 + SMTP_SECURE=false (STARTTLS)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=bookings@anshapps.in
SMTP_PASS=
# From address (also accepts SMTP_FROM if EMAIL_FROM is unset)
EMAIL_FROM=bookings@anshapps.in
# Shown in inbox (defaults to "Ansh Bookings" if unset). Set empty to use address only.
EMAIL_FROM_NAME=Ansh Bookings
# Or set full header in one var (then EMAIL_FROM_NAME is ignored):
# EMAIL_FROM="Ansh Bookings <bookings@anshapps.in>"
# SMTP_FROM=bookings@anshapps.in

# Razorpay (billing)
# Public key used by browser checkout
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Server-only secret key
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Price in paise for Pro monthly plan (₹399 => 39900)
RAZORPAY_PRO_PLAN_AMOUNT_PAISA=39900

# Cashfree (payment gateway integration)
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
# TEST or PROD
CASHFREE_ENV=TEST

# Zoom — User OAuth (authorization code + PKCE), not Server-to-Server
# Create a General / OAuth app on Zoom Marketplace so each host can authorize; S2S-only apps use Account ID + account_credentials instead.
# Register each redirect URL under OAuth Redirect URL and OAuth Allow Lists (exact string match).
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=
# Local dev: defaults to http://localhost:3000/api/integrations/zoom/callback (override with this if your port differs)
ZOOM_REDIRECT_URI_LOCAL=
# Set to true only if you intentionally want production redirect_uri while running next dev
# ZOOM_USE_PRODUCTION_ZOOM_REDIRECT=true
# Optional: override default scopes (space-separated). Default: user:read:user meeting:write:meeting
# ZOOM_OAUTH_SCOPES=user:read:user meeting:write:meeting
