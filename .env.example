NEXT_PUBLIC_SUPABASE_URL=
# Use either JWT anon key (legacy) or new publishable key from Supabase dashboard:
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional server-only aliases (API route also reads these):
SUPABASE_URL=
SUPABASE_ANON_KEY=
# App + Prisma runtime (Next API). Prefer Supabase pooler for serverless, e.g.:
# postgresql://postgres.PROJECT:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DATABASE_URL=
# Prisma CLI only (migrate / db push): direct Postgres, not transaction-pooler. Example:
# postgresql://postgres:[PASSWORD]@db.PROJECT.supabase.co:5432/postgres?sslmode=require
DIRECT_URL=
