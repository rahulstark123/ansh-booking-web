NEXT_PUBLIC_SUPABASE_URL=
# Use either JWT anon key (legacy) or new publishable key from Supabase dashboard:
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional server-only aliases (API route also reads these):
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Prisma + Supabase (pooler — from Dashboard → Connect → ORM: Prisma)
# Port 6543 + pgbouncer=true = transaction pooler (Next API / `src/lib/prisma.ts`)
# Port 5432 on same host = session mode for Prisma CLI (`prisma.config.ts` uses DIRECT_URL first)
# Example (replace password; URL-encode @ # in password):
# DATABASE_URL="postgresql://postgres.eajcpzzegjpixkhaohjd:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# DIRECT_URL="postgresql://postgres.eajcpzzegjpixkhaohjd:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require"
DATABASE_URL=
DIRECT_URL=

# Transactional email (booking confirmations)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Razorpay (billing)
# Public key used by browser checkout
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Server-only secret key
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Price in paise for Pro monthly plan (₹399 => 39900)
RAZORPAY_PRO_PLAN_AMOUNT_PAISA=39900
